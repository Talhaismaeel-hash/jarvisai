# ---------------------------------------------------------------------------
# Project JARVIS — environment variables
# Copy this file to .env.local and fill in real values.
# Nothing here is required for `npm run dev` to work — the app runs fully
# on mock data until you wire up Supabase and an AI provider.
# ---------------------------------------------------------------------------

# Supabase (auth + database) — see lib/supabase/client.ts and server.ts
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider — used once /api/chat is connected to a real model
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
